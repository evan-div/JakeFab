# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# Required. Get a free API key at https://resend.com (no credit card, no
# domain verification needed to get started — see README for details).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional. Where quote-request emails are sent. Defaults to `site.email`
# in src/data/site.ts if unset.
QUOTE_TO_EMAIL=wall.d.jake@gmail.com
